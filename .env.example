# TTS provider.
TTS_PROVIDER=minimax

# MiniMax TTS (Speech-2.8-HD)
# ⚠️ 安全提醒：请勿在此文件写入真实 API 密钥，使用环境变量或 .env.local
MINIMAX_TTS_API_KEY=your_minimax_tts_api_key_here
MINIMAX_TTS_MODEL=speech-2.8-hd
# 中文音色：电台主持人
MINIMAX_TTS_VOICE_ID_ZH=Chinese (Mandarin)_Radio_Host
# 英文音色：Santa Claus
MINIMAX_TTS_VOICE_ID_EN=Santa_Claus
# 默认音色（回退）
MINIMAX_TTS_VOICE_ID=Chinese (Mandarin)_Radio_Host

# Volcengine TTS (备用)
VOLCENGINE_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional
# ⚠️ 安全提醒：请勿在此文件写入真实 API 密钥，使用环境变量或 .env.local
VOLCENGINE_TTS_API_KEY=your_volcengine_api_key_here
VOLCENGINE_TTS_RESOURCE_ID=volc.service_type.10029
VOLCENGINE_TTS_VOICE_TYPE=zh_male_wennuanahu_uranus_bigtts
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000
CALLER_TTS_RESOURCE_ID=seed-tts-2.0
CALLER_TTS_VOICE_TYPE=zh_male_wennuanahu_uranus_bigtts

# DJ Voice - Chinese (used when DJ language is zh)
# 使用大模型语音合成 2.0 - 鸡汤妹 (uranus_bigtts 版本，对应 seed-tts-2.0)
VOLCENGINE_TTS_VOICE_TYPE_ZH=zh_female_jitangmei_uranus_bigtts
VOLCENGINE_TTS_RESOURCE_ID_ZH=seed-tts-2.0

# Music provider.
MUSIC_PROVIDER=auto
NETEASE_API_BASE=http://127.0.0.1:3001
NETEASE_LEVEL=standard
NETEASE_COOKIE=

# LLM provider: deepseek | claude_cli | minimax
LLM_PROVIDER=minimax

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Minimax
# ⚠️ 安全提醒：请勿在此文件写入真实 API 密钥，使用环境变量或 .env.local
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# Skip Netease QR login bootstrap (keep false if local cookie works)
NETEASE_LOGIN_BOOTSTRAP=false

# QQ Music recommendations (optional).
# When QQMUSIC_API_KEY is set, Claudio pulls the daily 30 recommendations at
# boot and every day at 09:00, then asks the DJ to prefer those tracks.
# Get your key at https://y.qq.com/n/ryqq_v2/qqmusic_skills
QQMUSIC_API_KEY=
QQMUSIC_API_BASE=https://a.y.qq.com
